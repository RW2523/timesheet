# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://timesheet_user:timesheet_pass@postgres:5432/timesheet_ai

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_ROOT=/storage
MAX_UPLOAD_MB=2000
MAX_EXTRACTED_MB=5000

# ── LLM (disabled by default — enable when TRT-LLM is running on DGX Spark) ──
LLM_ENABLED=false
LLM_BASE_URL=http://trt-llm:8000/v1
PRIMARY_LLM_MODEL=nvidia/Nemotron-3-Nano-Omni-30B-A3B-Reasoning-NVFP4
LLM_TIMEOUT=120

# ── OCR ───────────────────────────────────────────────────────────────────────
OCR_ENABLED=true
OCR_USE_GPU=false
TESSERACT_ENABLED=true
OCR_CONFIDENCE_THRESHOLD=0.7

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production-use-32-char-min
ALLOWED_ORIGINS=http://localhost:3000

# ── Payroll Settings ──────────────────────────────────────────────────────────
REGULAR_DAILY_LIMIT_HOURS=8
REGULAR_WEEKLY_LIMIT_HOURS=40
MAX_DAILY_HOURS=12
LATE_SUBMISSION_DAYS=5
INACTIVE_MONTHS_THRESHOLD=2

# ── Noise files to ignore during ZIP extraction ───────────────────────────────
NOISE_FILE_PATTERNS=desktop.ini,thumbs.db,.ds_store,.gitkeep,__macosx
